@model SnackMVCApp.Models.Snack

@{
    ViewData["Title"] = "Edit Snack";
}

<h2 class="mb-4">Edit Snack</h2>

@* enctype="multipart/form-data" required for file uploads *@
<form asp-action="Edit" method="post" enctype="multipart/form-data">

    <input type="hidden" asp-for="Id" />

    @* Preserve existing ImageUrl so it's not lost if no new image is uploaded *@
    <input type="hidden" asp-for="ImageUrl" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Brand" class="form-label"></label>
        <input asp-for="Brand" class="form-control" />
        <span asp-validation-for="Brand" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type"
                class="form-select"
                asp-items="Html.GetEnumSelectList<SnackMVCApp.Models.SnackType>()">
        </select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Rating" class="form-label"></label>
        <select asp-for="Rating" class="form-select">
            <option value="">Select Rating</option>
            <option value="1">⭐</option>
            <option value="2">⭐⭐</option>
            <option value="3">⭐⭐⭐</option>
            <option value="4">⭐⭐⭐⭐</option>
            <option value="5">⭐⭐⭐⭐⭐</option>
        </select>
        <span asp-validation-for="Rating" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    @* CURRENT IMAGE PREVIEW *@
    <div class="mb-3">
        <label class="form-label">
            <i class="fa-solid fa-image"></i> Current Image
        </label>
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div>
                <img src="@Model.ImageUrl"
                     alt="@Model.Name"
                     style="height:120px; width:160px; object-fit:cover; border-radius:8px; border:2px solid #A0D585;"
                     class="mb-2" />
            </div>
        }
        else
        {
            <p class="text-muted">
                <i class="fa-solid fa-image"></i> No image uploaded yet.
            </p>
        }
    </div>

    @* UPLOAD NEW IMAGE *@
    <div class="mb-3">
        <label asp-for="ImageFile" class="form-label">
            Upload New Image (optional — replaces current)
        </label>
        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
        <span class="text-muted" style="font-size:0.85rem">
            Leave empty to keep current image.
        </span>
    </div>

    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-save"></i> Save Changes
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
