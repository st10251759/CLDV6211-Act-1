@model IEnumerable<SnackMVCApp.Models.Snack>

@{
    ViewData["Title"] = "Snack List";
}

<h2 class="mb-4">Snack List</h2>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2" style="max-width: 700px;">

        ```
        <!--Search box -->
        <div class="col-md-6">
            <input type="text"
                   name="searchString"
                   value="@ViewData["CurrentFilter"]"
                   class="form-control"
                   placeholder="Search snacks (name, brand, description...)" />
        </div>

        <!-- Type dropdown -->
        <div class="col-md-4">
            <select name="type" class="form-select">
                <option value="">All Types</option>
                <option value="Chips" selected="@(ViewData["CurrentType"]?.ToString() == "Chips")">Chips</option>
                <option value="Candy" selected="@(ViewData["CurrentType"]?.ToString() == "Candy")">Candy</option>
                <option value="Drink" selected="@(ViewData["CurrentType"]?.ToString() == "Drink")">Drink</option>
                <option value="Chocolate" selected="@(ViewData["CurrentType"]?.ToString() == "Chocolate")">Chocolate</option>
                <option value="Biscuit" selected="@(ViewData["CurrentType"]?.ToString() == "Biscuit")">Biscuit</option>
            </select>
        </div>

        <!-- 🔘 Buttons -->
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
            <a asp-action="Index" class="btn btn-secondary w-100">
                Clear
            </a>
        </div>

    </div>
    ```

</form>

<a asp-action="Create" class="btn btn-success mb-3">
    <i class="fa-solid fa-plus"></i> Add Snack
</a>

<table class="table table-hover table-bordered">
    <thead style="background-color:#A0D585">
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Brand</th>
            <th>Type</th>
            <th>Description</th>
            <th>Rating</th>
            <th>Price</th>
            <th style="width:280px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="text-center" style="width:90px;">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl"
                             alt="@item.Name"
                             style="height:55px; width:75px; object-fit:cover; border-radius:6px;" />
                    }
                    else
                    {
                        <span class="text-muted">
                            <i class="fa-solid fa-image fa-lg"></i>
                        </span>
                    }
                </td>

                ```
                <td>@item.Name</td>
                <td>@item.Brand</td>
                <td>@item.Type</td>
                <td>@item.Description</td>

                <td>
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= item.Rating)
                        {
                            <i class="fa-solid fa-star text-warning"></i>
                        }
                        else
                        {
                            <i class="fa-regular fa-star text-warning"></i>
                        }
                    }
                </td>

                <td>R @item.Price.ToString("0.00")</td>

                <td class="text-center">
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info action-btn">
                            <i class="fa-solid fa-eye"></i> View
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary action-btn">
                            <i class="fa-solid fa-pen"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger action-btn">
                            <i class="fa-solid fa-trash"></i> Delete
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>

</table>
